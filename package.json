{
  "name": "milky-way",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist && node scripts/subset-fonts.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "typecheck": "astro check",
    "test:rss": "node scripts/verify-rss.mjs",
    "test:e2e": "playwright test",
    "check:friends": "node scripts/check-friend-links.mjs",
    "verify": "npm run typecheck && npm test && npm run build && npm run test:rss && npm run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/rss": "^4.0.11",
    "@netlify/blobs": "^8.2.0",
    "@netlify/functions": "^5.3.0",
    "@tailwindcss/vite": "^4.1.6",
    "astro": "^7.0.9",
    "medium-zoom": "^1.1.0",
    "rehype-external-links": "^3.0.0",
    "tailwindcss": "^4.1.6",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@netlify/plugin-lighthouse": "^6.0.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.3",
    "subset-font": "^2.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
