---
import { getCollection } from 'astro:content';
import { getWordCount } from '../utils/wordCount';
const year = new Date().getFullYear();
// 拿到所有文章
const posts = await getCollection('posts');

// 计算总字数（复用你已有的 getWordCount 工具函数）
const totalWordCount = posts.reduce((sum, post) => {
  return sum + getWordCount(post.body, { onlyChinese: true });
}, 0);

// 设定博客搭建日期
const earliestDate = new Date(2025, 4, 9);

// 字数转换成"千字"为单位，保留一位小数
const wordCountInThousands = (totalWordCount / 1000).toFixed(1);
---

<footer>
  <div class="center">
    <ul class="footer">
      <li class="icon__btn">
        <a
          class="icon__link"
          href="https://stelpolva.moe/@bipolar"
          target="_blank"
          aria-label="星屑"
          >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            xml:space="preserve"
            viewBox="0.01 76.52 512 358.88"
            fill="#fff"
