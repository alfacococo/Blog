    <p class="footer-stats">
      卷毛羊<del>登基</del>圈地已经 <span id="days-count">0</span> 天，<br
      />咩咩了 {wordCountInThousands} 千字的废话
    </p>
    <small>&copy; {year} Curly Sheep by 卷毛羊. All Rights Reserved.</small>
  </div>
</footer>

<style>
  .footer-stats {
    font-size: 0.85rem;
    opacity: 0.6;
    margin: 0.5rem 0;
  }
</style>

<script is:inline data-astro-rerun define:vars={{ earliestDate }}>
  // 在客户端运行的脚本
  const start = new Date(earliestDate);
  const now = new Date();
  // 计算从最早那篇文章到今天，一共多少天
  const diff = Math.floor((now - start) / (1000 * 60 * 60 * 24));
  document.getElementById('days-count').innerText = diff;
</script>
