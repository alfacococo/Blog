            viewBox="0 0 24 24"
            class="masterdon-icon w-[20px] h-[20px] absolute top-1/2 left-1/2"
            xmlns="http://www.w3.org/2000/svg"
            ><path
              d="M20.9,20.986h0v0Zm-6.526-13.9A17.647,17.647,0,0,0,3.105,3V7.116a14.1,14.1,0,0,1,12.067,6.722,13.792,13.792,0,0,1,2.013,7.148H20.9A18.048,18.048,0,0,0,14.369,7.081Zm-8.958,9.3a2.306,2.306,0,1,0,2.306,2.306A2.308,2.308,0,0,0,5.411,16.381Zm4.947-4.29A11.434,11.434,0,0,0,3.105,9.506v3.465a8.022,8.022,0,0,1,7.009,4.109A8.12,8.12,0,0,1,11.127,21h3.48v-.007A11.527,11.527,0,0,0,10.358,12.091Z"
