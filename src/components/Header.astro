---
import Navigation from "./Navigation.astro";
---

<header class="site-header">
  <nav transition:persist>
    <Navigation />
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 50%;
    width: 100%;
    max-width: 600px;
    margin-bottom: 1rem;
    transform: translateX(-50%);
    transition: transform 0.3s ease;
    z-index: 99;
    background-color: var(--background);
  }
  .site-header.header-hidden {
    transform: translateX(-50%) translateY(-100%);
  }
</style>

<script>
  function initSmartHeader() {
    let lastScrollY = window.scrollY;
    let ticking = false;
    let upScrollAccum = 0; // 累计上滑距离
    const SHOW_THRESHOLD = 80; // 累计上滑超过这个距离才显示，可以自己调
    const header = document.querySelector(".site-header") as HTMLElement;

    if (!header) return;

    function updateHeader() {
      const currentScrollY = window.scrollY;
      const delta = currentScrollY - lastScrollY; // 正数=往下滑，负数=往上滑

      if (delta > 0) {
        // 往下滑：重置累计值，隐藏 header
        upScrollAccum = 0;
        if (currentScrollY > 80) {
          header.classList.add("header-hidden");
        }
      } else if (delta < 0) {
        // 往上滑：累加上滑距离
        upScrollAccum += Math.abs(delta);
        if (upScrollAccum > SHOW_THRESHOLD) {
          header.classList.remove("header-hidden");
        }
      }

      // 滚动到顶部附近时，无论方向都强制显示
      if (currentScrollY <= 80) {
        header.classList.remove("header-hidden");
        upScrollAccum = 0;
      }

      lastScrollY = currentScrollY;
      ticking = false;
    }

    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    });
  }

  initSmartHeader();
  document.addEventListener("astro:page-load", initSmartHeader);
</script>
