---
interface Props {
  className?: string;
  alt?: string;
  width?: number;
  height?: number;
}

const {
  className = 'hero-image',
  alt = '',
  width = 400,
  height = 259,
} = Astro.props;
---

<picture>
  <source media="(prefers-color-scheme: light)" srcset="/images/mv.webp" />
  <img
    class:list={['mx-auto hero-image', className]}
    src="/images/mv-dark.webp"
    alt={alt}
    width={width}
    height={height}
    fetchpriority="high"
  />
</picture>
<script is:inline data-astro-rerun>
  // <picture> + prefers-color-scheme 让浏览器在解析 HTML 时就能原生选对图片，
  // 预加载扫描器不用等任何 JS 跑完就能发现并高优先级抓取——这是相对于纯 JS 判断主题
  // 的关键区别：之前那版不管命不命中，脚本都会重新赋一次 src，Lighthouse 的无痕测试
  // 环境没有 localStorage、也没开系统深色模式，会被判成"浅色"，于是每次都先按默认的
  // mv-dark.webp 抓一次图，脚本马上又切到 mv.webp 再抓一次，两次高优先级图片请求在
  // 限速网络下会抢 Layout 关键 CSS 的带宽，直接把 LCP/FCP 拖差了一截。
  // 现在这段脚本只处理"手动切换主题、跟系统偏好不一致"这一种少数情况：多数情况下
  // （没手动切换过，跟着系统走）这里设置的值跟 <picture> 原生选好的完全一样，
  // 浏览器发现 URL 没变就不会重新发请求，不会有额外开销。
  // MutationObserver 盯着 html 的 class：无论是首次加载时的纠正、软导航后重新解析出
  // 的新 img，还是用户点了 ThemeIcon 按钮手动切主题，都统一走同一条同步逻辑。
  // data-astro-rerun 原因同 Layout.astro 里的主题脚本——ClientRouter 软导航不会重新
  // 执行普通内联脚本，需要这个属性显式声明每次都要重跑，从而对新页面的 img 也纠正一次初始状态。
  (function () {
    function syncHeroImages() {
      var isLight = document.documentElement.classList.contains('light');
      document.querySelectorAll('.hero-image').forEach(function (img) {
        img.src = isLight ? '/images/mv.webp' : '/images/mv-dark.webp';
      });
    }

    syncHeroImages();

    if (!window.__heroThemeObserverBound) {
      window.__heroThemeObserverBound = true;
      new MutationObserver(syncHeroImages).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });
    }
  })();
</script>
