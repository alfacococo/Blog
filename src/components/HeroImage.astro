---
interface Props {
  className?: string;
  alt?: string;
  width?: number;
  height?: number;
}

const {
  className = 'hero-image',
  alt = '',
  width = 400,
  height = 259,
} = Astro.props;
---

<picture>
  <source media="(prefers-color-scheme: light)" srcset="/images/mv.webp" />
  <img
    class:list={['mx-auto hero-image', className]}
    src="/images/mv-dark.webp"
    alt={alt}
    width={width}
    height={height}
    fetchpriority="high"
  />
</picture>
<script is:inline data-astro-rerun>
  // <picture> + prefers-color-scheme 让浏览器在解析 HTML 时就能原生选对图片，
  // 预加载扫描器不用等任何 JS 跑完就能发现并高优先级抓取，这对没手动切换过主题的用户
  // （包括 Lighthouse 的无痕测试环境）是零 JS、零额外请求的路径。
  //
  // 但 <source media="(prefers-color-scheme: light)"> 只认系统实际的深浅色偏好，跟
  // 我们自己维护的 html.light class（手动切换按钮改的就是这个）是两套独立的判断——
  // 按规范，只要 <source> 命中了，就算再用 JS 显式设置 img.src 也会被原生选源逻辑
  // 覆盖回去，JS 设置的 src 只有在没有任何 <source> 命中时才真正生效。所以手动切换过
  // 主题、且跟系统偏好不一致时，必须把 <source> 摘掉，让 img 的 src 完全交给我们自己
  // 接管，否则图片永远会被系统偏好"纠正"回去，跟手动选的主题对不上。
  (function () {
    function detachPictureSources() {
      document.querySelectorAll('.hero-image').forEach(function (img) {
        var picture = img.closest('picture');
        if (picture) {
          picture.querySelectorAll('source').forEach(function (source) {
            source.remove();
          });
        }
      });
    }

    function syncHeroImages() {
      var isLight = document.documentElement.classList.contains('light');
      document.querySelectorAll('.hero-image').forEach(function (img) {
        img.src = isLight ? '/images/mv.webp' : '/images/mv-dark.webp';
      });
    }

    // 只有手动选过主题（localStorage 有值）才需要接管，没选过的完全不碰，
    // 交给 <picture> 原生处理。
    if (localStorage.getItem('theme')) {
      detachPictureSources();
      syncHeroImages();
    }

    if (!window.__heroThemeObserverBound) {
      window.__heroThemeObserverBound = true;
      new MutationObserver(function () {
        // class 变了说明用户点了切换按钮，从这一刻起就是手动模式，同样要摘掉
        // source 才能让 src 真正生效。
        detachPictureSources();
        syncHeroImages();
      }).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });
    }
  })();
</script>
