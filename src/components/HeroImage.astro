---
interface Props {
  className?: string;
  alt?: string;
  width?: number;
  height?: number;
}

const {
  className = 'hero-image',
  alt = '',
  width = 400,
  height = 259,
} = Astro.props;
---

<img
  class:list={['mx-auto hero-image', className]}
  alt={alt}
  width={width}
  height={height}
  fetchpriority="high"
/>
