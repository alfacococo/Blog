---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
  showNewBadgeOnFirstItem?: boolean;
  showTags?: boolean;
}

const {
  posts,
  showNewBadgeOnFirstItem = false,
  showTags = false,
} = Astro.props;
---

<ul role="list" class="mt-6 space-y-4">
  {
    posts.map((post, index) => (
      <li>
        <a
          href={`/posts/${post.id}/`}
          data-post-card
          data-post-tags={JSON.stringify(post.data.tags ?? [])}
          class="timeline-card group block rounded-2xl border-[var(--line-color)] bg-[var(--background)]/80 p-5 transition duration-300 ease-in-out hover:-translate-y-2.5 active:-translate-y-2.5"
        >
          <div class="flex flex-col gap-3 sm:items-start sm:justify-between">
            <div class="flex flex-col gap-2 sm:min-w-[110px]">
              <div class="flex items-center gap-2 flex-wrap">
                <time class="whitespace-nowrap text-sm text-[var(--text-light)] badge">
                  {post.data.date}
                </time>
                {showTags && post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full border border-[var(--line-color)] px-2 py-0.5 text-[11px] text-[var(--text)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                {showNewBadgeOnFirstItem && index === 0 && (
                  <span class="rounded-full bg-red-400 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-white">
                    NEW
                  </span>
                )}
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-[var(--text)]">
                {post.data.title}
              </h3>
              {post.data.description && (
                <p class="mt-2 text-sm leading-6 text-[var(--text)]">
                  {post.data.description}
                </p>
              )}
            </div>
          </div>
        </a>
      </li>
    ))
  }
</ul>

<script>
  import { onNavigate } from '../scripts/onNavigate';
  import { attachPressFeedback } from '../scripts/attachPressFeedback';

  onNavigate(() => attachPressFeedback('a[data-post-card]'));
</script>
