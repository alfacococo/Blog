---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
  showNewBadgeOnFirstItem?: boolean;
  showTags?: boolean;
}

const {
  posts,
  showNewBadgeOnFirstItem = false,
  showTags = false,
} = Astro.props;
---

<ul role="list" class="mt-6 space-y-4">
  {
    posts.map((post, index) => (
      <li>
        <a
          href={`/posts/${post.id}/`}
          data-post-card
          data-post-slug={post.id}
          data-post-tags={JSON.stringify(post.data.tags ?? [])}
          class="timeline-card group block rounded-2xl border-[var(--line-color)] bg-[var(--background)]/80 p-5 transition duration-300 ease-in-out hover:-translate-y-2.5 active:-translate-y-2.5"
        >
          <div class="flex flex-col gap-3 sm:items-start sm:justify-between">
            <div class="flex flex-col gap-2 sm:min-w-[110px]">
              <div class="flex items-center gap-2 flex-wrap">
                <time class="whitespace-nowrap text-sm text-[var(--text-light)] badge">
                  {post.data.date}
                </time>
                {showTags && post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full border border-[var(--line-color)] px-2 py-0.5 text-[11px] text-[var(--text)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                {showNewBadgeOnFirstItem && index === 0 && (
                  <span class="rounded-full bg-red-400 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-white">
                    NEW
                  </span>
                )}
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-[var(--text)]">
                {post.data.title}
              </h3>
              {post.data.description && (
                <p class="mt-2 text-sm leading-6 text-[var(--text)]">
                  {post.data.description}
                </p>
              )}
            </div>
          </div>
          <span class="read-stamp" aria-hidden="true">
            <img
              src="/images/read-stamp.png"
              alt=""
              width="341"
              height="308"
              loading="lazy"
              decoding="async"
            />
          </span>
        </a>
      </li>
    ))
  }
</ul>

<script>
  import { onNavigate } from '../scripts/onNavigate';
  import { attachPressFeedback } from '../scripts/attachPressFeedback';
  import { getReadSlugs } from '../scripts/readPosts';

  function markReadCards() {
    const readSlugs = getReadSlugs();
    document
      .querySelectorAll<HTMLElement>('a[data-post-card]')
      .forEach((card) => {
        const slug = card.dataset.postSlug;
        card.classList.toggle('is-read', !!slug && readSlugs.has(slug));
      });
  }

  onNavigate(() => attachPressFeedback('a[data-post-card]'));
  onNavigate(markReadCards);
</script>

<style>
  .timeline-card {
    position: relative;
    overflow: hidden;
  }

  /* 图源裁掉透明边之后是 341x308，用 aspect-ratio 锁住这个真实比例，
     宽度定死、高度跟着比例走，避免图章被拉伸变形。 */
  .read-stamp {
    position: absolute;
    top: -19px;
    right: -15px;
    width: 90px;
    aspect-ratio: 341 / 308;
    transform: rotate(-12deg) scale(0.85);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .read-stamp img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .timeline-card.is-read .read-stamp {
    opacity: 0.92;
    transform: rotate(-12deg) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .read-stamp {
      transition: none;
    }
  }
</style>
