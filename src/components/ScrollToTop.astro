<style>
  .scroll-top {
    position: fixed;
    bottom: 2.5rem;
    right: 2.5rem;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    border: none;
    padding: 0.75rem;
    border-radius: 50%;
    font-size: 1.25rem;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.3s ease;
    z-index: 1000;
    backdrop-filter: blur(4px);
  }

  .scroll-top svg {
    width: 20px;
    height: 20px;
    display: block;
    margin: auto;
    fill: white;
  }

  .scroll-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .scroll-top:not(.visible) {
    transform: translateY(20px);
  }
</style>

<button id="scroll-top-button" class="scroll-top" aria-label="回到顶部">
  <!-- SVG 上箭头图标 -->
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
    <path fill-rule="evenodd" d="M3.293 12.707a1 1 0 011.414 0L10 7.414l5.293 5.293a1 1 0 001.414-1.414l-6-6a1 1 0 00-1.414 0l-6 6a1 1 0 010 1.414z" clip-rule="evenodd"/>
  </svg>
</button>

<script>
  import { onNavigate } from '../scripts/onNavigate';

  function updateScrollToTopVisibility() {
    const btn = document.getElementById('scroll-top-button');
    if (!btn) return;
    if (window.scrollY > 300) {
      btn.classList.add('visible');
    } else {
      btn.classList.remove('visible');
    }
  }

  function initScrollToTop() {
    const btn = document.getElementById('scroll-top-button');
    if (!btn) return;

    btn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth',
      });
    });

    // 每次进入页面时，根据当前滚动位置立刻校正一次按钮显隐状态
    // （不然切换页面后它会一直停留在刚进入页面时的隐藏状态，直到下次滚动才会更新）
    updateScrollToTopVisibility();
  }

  // scroll 监听器只需要绑定一次：window 对象在 SPA 导航过程中不会被替换，
  // 每次触发时都重新查询当前页面的按钮，就不会有“引用到已经被替换掉的旧节点”的问题
  onNavigate(() => window.addEventListener('scroll', updateScrollToTopVisibility), { once: true });

  onNavigate(initScrollToTop);
</script>
