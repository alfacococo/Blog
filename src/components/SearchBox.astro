<div id="search-container">
  <button id="search-trigger" aria-label="搜索文章">Search</button>
</div>

<script>
  import { onNavigate } from '../scripts/onNavigate';

  function initSearch() {
    const trigger = document.getElementById('search-trigger');
    const modal = document.getElementById('search-modal');
    const closeBtn = document.getElementById('search-close');
    const results = document.getElementById('search');
    if (!trigger || !modal || !closeBtn || !results) return;

    // modal 现在直接写在 Layout.astro 里作为 Header 的同级兄弟节点，
    // 不再嵌套在持久化的 nav 里面了，所以不需要再用 JS 把它挑到 body 下面，
    // 它自己的 transition:persist 能直接稳定生效

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        modal.classList.add('hidden');
      }
    });

    // idle | loading | ready：防止重复注入 script，也让 hover/focus 预加载和
    // 点击时的加载共用同一份状态
    let uiState: 'idle' | 'loading' | 'ready' = 'idle';

    function loadPagefindUI() {
      if (uiState !== 'idle') return;
      uiState = 'loading';

      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = () => {
        new (window as any).PagefindUI({
          element: '#search',
          excerptLength: 50,
          showImages: false, // 没有任何页面标了 data-pagefind-meta="image"，缩略图区域永远空着，不如直接关掉
        });
        uiState = 'ready';
      };
      document.body.appendChild(script);
    }

    // 预加载：浏览器空闲时，或用户 hover/focus 到搜索按钮时（两者取先到者），
    // 提前把 pagefind-ui.js 加载好，这样真正点击时大概率已经就绪，不占首屏关键路径
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(loadPagefindUI, { timeout: 4000 });
    } else {
      setTimeout(loadPagefindUI, 2000);
    }
    trigger.addEventListener('mouseenter', loadPagefindUI, { once: true });
    trigger.addEventListener('focus', loadPagefindUI, { once: true });

    trigger.addEventListener('click', () => {
      modal.classList.remove('hidden');
      loadPagefindUI(); // 若已在预加载中或已就绪，内部会直接跳过
    });

    closeBtn.addEventListener('click', () => modal.classList.add('hidden'));
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.add('hidden');
    });

    // pagefind-ui 的搜索结果是点击后才动态插入到 #search 里的 <a> 标签，
    // 所以用事件委托绑在 #search 容器上，而不是等结果出现了再逐个绑定
    results.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) {
        modal.classList.add('hidden');
      }
    });
  }

  // trigger/modal/closeBtn 都在持久化的节点里，SPA 导航中不会被销毁重建，
  // 所以只需要在真正的第一次绑定一次就够了
  onNavigate(initSearch, { once: true });
</script>
