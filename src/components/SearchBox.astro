<div id="search-container">
  <button id="search-trigger" aria-label="搜索文章">Search</button>
</div>

<script>
  function initSearch() {
    const trigger = document.getElementById('search-trigger');
    const modal = document.getElementById('search-modal');
    const closeBtn = document.getElementById('search-close');
    if (!trigger || !modal || !closeBtn) return;

    // modal 现在直接写在 Layout.astro 里作为 Header 的同级兄弟节点，
    // 不再嵌套在持久化的 nav 里面了，所以不需要再用 JS 把它挑到 body 下面，
    // 它自己的 transition:persist 能直接稳定生效

    // trigger 在持久化的 nav 里面，SPA 导航中不会被销毁重建，是同一个节点一直活到现在；
    // modal/closeBtn 现在也能正确持久化了，事件监听器只需要绑一次，
    // 用 dataset 标记避免每次切页都叠加一个新的监听器
    if (trigger.dataset.searchBound) return;
    trigger.dataset.searchBound = 'true';

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        modal.classList.add('hidden');
      }
    });

    let uiLoaded = false;

    trigger.addEventListener('click', () => {
      modal.classList.remove('hidden');

      if (!uiLoaded) {
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = () => {
          new (window as any).PagefindUI({
            element: '#search',
            excerptLength: 50,
          });
        };
        document.body.appendChild(script);
        uiLoaded = true;
      }
    });

    closeBtn.addEventListener('click', () => modal.classList.add('hidden'));
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.add('hidden');
    });
  }

  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>
