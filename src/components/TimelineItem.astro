---
// props: time（时间）, children（插槽内容）
const { time } = Astro.props;
---

<li
  class="flex mb-4 items-start gap-2 flex-col bg-[#102] p-4 rounded-2xl timeline-card transition duration-300 ease-in-out hover:-translate-y-2 hover:shadow-md shadow-sm"
>
  <time class="post-date badge--item badge min-w-[81px] block">{time}</time>
  <div class="inline-block">
    <slot />
  </div>
</li>
