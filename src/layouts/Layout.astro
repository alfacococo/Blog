---
import { ClientRouter, fade } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import SeoMeta from '../components/SeoMeta.astro';
import SearchModal from '../components/SearchModal.astro';
import '../styles/global.css';

interface Props {
  pageTitle: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  pageTitle,
  description = '羊星居羊卷卷。喜欢嘟囔一些日常小事，很少进行大思考的赛博羊圈。',
  image = '/images/favicon.ico',
  type = 'website',
} = Astro.props;
---

<!doctype html>
<html transition:animate={fade({ duration: '250ms' })} lang="zh-cmn-Hans">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- 提前预加载这三个 @font-face 字体（见 fonts.css），不然浏览器要等 CSS
         解析完、发现真的有文字要用它们才会开始下载。LXGWNeoXiHei 子集有 334 KiB，
         手机网络上够不上瞬间下载完，字体没下载完的这段时间 font-display: swap
         会先显示兜底字体——以前切页是硬切感知不到，现在换成 250ms 淡入淡出后
         这个过程会被看见，预加载能尽量缩短这个窗口。 -->
    <link rel="preload" href="/fonts/LXGWNeoXiHei.subset.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Pacifico-Regular.subset.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JosefinSans-Regular.subset.woff2" as="font" type="font/woff2" crossorigin />

    <SeoMeta pageTitle={pageTitle} description={description} image={image} type={type} />

    <!-- pagefind 搜索组件的样式表。固定写在 head 里而不是用 JS 动态注入，
         这样新旧页面的 head 里 href 能对上，Astro 切页时才会自动保留它，
         不会像之前那样切一次页就丢一次。
         media="print" + onload 切回 all 是标准的异步样式表加载法：浏览器对 print
         样式表不阻塞渲染，加载完成后再启用。这些样式只有打开搜索弹窗才用得上，
         不值得为它挡住首屏；切页时即使元素被替换重新走一遍 onload，弹窗没开也无感。 -->
    <link
      rel="stylesheet"
      href="/pagefind/pagefind-ui.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript><link rel="stylesheet" href="/pagefind/pagefind-ui.css" /></noscript>

    <script is:inline data-astro-rerun>
      // data-astro-rerun 会让这段脚本在每次 ClientRouter 软导航时都重新执行一次。
      // 但经典（非 module）脚本的顶层 const/let 声明是挂在整个页面共享的全局词法作用域上的，
      // 不会因为是"新的一次执行"就重新清空——所以如果不包一层 IIFE，
      // 第二次软导航时再执行到 `const theme = ...` 就会直接抛
      // "Identifier 'theme' has already been declared"，把这次导航剩下的脚本执行全部打断。
      (function () {
        const theme = (() => {
          if (
            typeof localStorage !== 'undefined' &&
            localStorage.getItem('theme')
          ) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            return 'light';
          }
          return 'dark';
        })();

        if (theme === 'dark') {
          document.documentElement.classList.remove('light');
        } else {
          document.documentElement.classList.add('light');
        }

        window.localStorage.setItem('theme', theme);

        if (!window.__themeBeforeSwapBound) {
          window.__themeBeforeSwapBound = true;
          document.addEventListener('astro:before-swap', (event) => {
            const isLight = document.documentElement.classList.contains('light');
            if (isLight) {
              event.newDocument.documentElement.classList.add('light');
            }
          });
        }

        function initTitleEffect() {
          const originalTitle = document.title;
          const awayTitle = '(つ•̀ω•́)つ 羊等你回来~';
          const backTitle = '欢迎回来！ヽ(・∀・)ﾉ ';

          let hasHidden = false;
          let timer = null;

          if (window.__titleEffectBound) return;
          window.__titleEffectBound = true;

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              hasHidden = true;

              clearTimeout(timer);
              document.title = awayTitle;
            } else {
              if (hasHidden) {
                document.title = backTitle;

                timer = setTimeout(() => {
                  document.title = originalTitle;
                }, 600);

                hasHidden = false;
              } else {
                document.title = originalTitle;
              }
            }
          });

          window.addEventListener('pageshow', () => {
            clearTimeout(timer);
            document.title = originalTitle;
          });
        }

        initTitleEffect();
      })();
    </script>
    <!-- Google tag (gtag.js)。dataLayer 桩子照常先建好把事件排队，但 gtag.js 本体
         推迟到 load 事件后的空闲时段再注入：它在慢速设备上会占主线程还触发强制重排
         （Lighthouse 的 TBT / 强制自动重排两项都指向它），统计脚本没必要跟首屏抢时间。
         排队的事件在脚本加载后会照常上报，不丢数据。 -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-Q3BM4LFJ6D');

      (function () {
        if (window.__gtagLoaderBound) return;
        window.__gtagLoaderBound = true;

        function loadGtag() {
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-Q3BM4LFJ6D';
          document.head.appendChild(s);
        }

        var idle =
          window.requestIdleCallback ||
          function (cb) {
            setTimeout(cb, 1500);
          };

        if (document.readyState === 'complete') {
          idle(loadGtag);
        } else {
          window.addEventListener(
            'load',
            function () {
              idle(loadGtag);
            },
            { once: true },
          );
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body class="mx-auto">
    <Header />
    <SearchModal />
    <main class=" mx-auto">
      <slot />
      <ScrollToTop />
      <Footer />
    </main>
    <script>
      import { onNavigate } from '../scripts/onNavigate';
      import { initPageTransitionScroll } from '../scripts/pageTransition';

      onNavigate(initPageTransitionScroll, { once: true });
    </script>
    <script type="module">
      function attachWalineObserver() {
        const container = document.getElementById('waline');
        // 用 dataset 标记标记当前这个容器是否已经绑过 observer，
        // 而不是用 window 上的全局标记。因为每次切换页面后，Astro 都会重新渲染一个
        // 全新的 #waline 容器，它的 dataset 自然是空的，不需要手动重置，
        // 也就不会像之前那样“第一次初始化过之后就永远不再初始化了”。
        if (!container || container.dataset.walineBound) return;
        container.dataset.walineBound = 'true';

        const observer = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (!entry?.isIntersecting) return;

            observer.disconnect();

            import('https://unpkg.com/@waline/client@v3/dist/waline.js').then(
              ({ init }) => {
                init({
                  el: '#waline',
                  serverURL:
                    'https://curly-sheeps-comments.netlify.app/.netlify/functions/comment',
                  locale: {
                    placeholder: '跟卷毛羊打个招呼再走吧！',
                    sofa: '咦怎么一个人都没有……',
                    submit: '咩咩',
                    login: '登录',
                    admin: '博主',
                    anonymous: '路过羊',
                  },
                });
              },
            );
          },
          { rootMargin: '300px 0px' },
        );

        observer.observe(container);
      }

      // astro:page-load 在首次加载和之后每次导航都会触发，所以不需要额外再手动调用一次，
      // 也避免了首次加载时被直接调用 + 事件触发双重触发的情况
      document.addEventListener('astro:page-load', attachWalineObserver);
    </script>
    <script>
      function colorMode() {
        if (
          localStorage.theme === 'light' ||
          (!('theme' in localStorage) &&
            window.matchMedia('(prefers-color-scheme: light)').matches)
        ) {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      }

      colorMode();
      document.addEventListener('astro:after-swap', colorMode);
    </script>
  </body>
</html>
