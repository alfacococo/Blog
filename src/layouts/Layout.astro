---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import '../styles/global.css';

interface Props {
  pageTitle: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  pageTitle,
  description = '羊星居羊卷卷。喜欢嘟囔一些日常小事，很少进行大思考的赛博羊圈。',
  image = '/images/favicon.ico',
  type = 'website',
} = Astro.props;

// 用于 og:url 和 og:image 的绝对地址，这些平台拉取卡片预览时需要绝对路径
const ogImageURL = new URL(image, Astro.site);
const pageURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html transition:animate="none" lang="zh-cmn-Hans">
  <head>
    <meta charset="utf-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#1e1e2e" />
    <link rel="icon" href="/images/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    <!-- Open Graph （分享到 Misskey / 长毛象等联邦宇宙时用于生成预览卡片） -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Curly Sheep" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card（一些联邦实例/客户端也会参考这套标签） -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- pagefind 搜索组件的样式表。固定写在 head 里而不是用 JS 动态注入，
         这样新旧页面的 head 里 href 能对上，Astro 切页时才会自动保留它，
         不会像之前那样切一次页就丢一次。体积很小，常驻也不影响首屏。 -->
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <script is:inline data-astro-rerun>
      const theme = (() => {
        if (
          typeof localStorage !== 'undefined' &&
          localStorage.getItem('theme')
        ) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          return 'light';
        }
        return 'dark';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.remove('light');
      } else {
        document.documentElement.classList.add('light');
      }

      window.localStorage.setItem('theme', theme);

      document.addEventListener('astro:before-swap', (event) => {
        const isLight = document.documentElement.classList.contains('light');
        if (isLight) {
          event.newDocument.documentElement.classList.add('light');
        }
      });

      function initTitleEffect() {
        const originalTitle = document.title;
        const awayTitle = '(つ•̀ω•́)つ 羊等你回来~';
        const backTitle = '欢迎回来！ヽ(・∀・)ﾉ ';

        let hasHidden = false;
        let timer = null;

        if (window.__titleEffectBound) return;
        window.__titleEffectBound = true;

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            hasHidden = true;

            clearTimeout(timer);
            document.title = awayTitle;
          } else {
            if (hasHidden) {
              document.title = backTitle;

              timer = setTimeout(() => {
                document.title = originalTitle;
              }, 600);

              hasHidden = false;
            } else {
              document.title = originalTitle;
            }
          }
        });

        window.addEventListener('pageshow', () => {
          clearTimeout(timer);
          document.title = originalTitle;
        });
      }

      initTitleEffect();
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q3BM4LFJ6D"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-Q3BM4LFJ6D');
    </script>
    <ClientRouter />
  </head>
  <body class="mt-[78px] mx-auto">
    <Header />
    <div id="search-modal" class="search-modal hidden" transition:persist>
      <div class="search-modal-content">
        <div id="search"></div>
        <button id="search-close" aria-label="关闭搜索">✕</button>
      </div>
    </div>
    <style>
      .search-modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 3000;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 10vh;
      }

      .search-modal.hidden {
        display: none;
      }

      .search-modal-content {
        background: var(--background);
        border-radius: 12px;
        padding: 1.5rem 2rem;
        width: 90%;
        max-width: 500px;
        max-height: 70vh;
        overflow-y: auto;
        position: relative;
      }

      #search-close {
        position: absolute;
        top: 2.5rem;
        transform: translateY(-50%);
        right: 0.5rem;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.2rem;
        line-height: 1;
        padding: 0;
      }
    </style>
    <main>
      <slot />
      <ScrollToTop />
      <Footer />
    </main>
    <script type="module">
      function attachWalineObserver() {
        const container = document.getElementById('waline');
        // 用 dataset 标记标记当前这个容器是否已经绑过 observer，
        // 而不是用 window 上的全局标记。因为每次切换页面后，Astro 都会重新渲染一个
        // 全新的 #waline 容器，它的 dataset 自然是空的，不需要手动重置，
        // 也就不会像之前那样“第一次初始化过之后就永远不再初始化了”。
        if (!container || container.dataset.walineBound) return;
        container.dataset.walineBound = 'true';

        const observer = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (!entry?.isIntersecting) return;

            observer.disconnect();

            import('https://unpkg.com/@waline/client@v3/dist/waline.js').then(
              ({ init }) => {
                init({
                  el: '#waline',
                  serverURL:
                    'https://curly-sheeps-comments.netlify.app/.netlify/functions/comment',
                  locale: {
                    placeholder: '跟卷毛羊打个招呼再走吧！',
                    sofa: '咦怎么一个人都没有……',
                    submit: '咩咩',
                    login: '登录',
                    admin: '博主',
                    anonymous: '路过羊',
                  },
                });
              },
            );
          },
          { rootMargin: '300px 0px' },
        );

        observer.observe(container);
      }

      // astro:page-load 在首次加载和之后每次导航都会触发，所以不需要额外再手动调用一次，
      // 也避免了首次加载时被直接调用 + 事件触发双重触发的情况
      document.addEventListener('astro:page-load', attachWalineObserver);
    </script>
    <script>
      function colorMode() {
        if (
          localStorage.theme === 'light' ||
          (!('theme' in localStorage) &&
            window.matchMedia('(prefers-color-scheme: light)').matches)
        ) {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      }

      colorMode();
      document.addEventListener('astro:after-swap', colorMode);
    </script>
  </body>
</html>
