---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import '../styles/global.css';

interface Props {
  pageTitle: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  pageTitle,
  description = '羊星居羊卷卷。喜欢嘟囔一些日常小事，很少进行大思考的赛博羊圈。',
  image = '/images/favicon.ico',
  type = 'website',
} = Astro.props;

// 用于 og:url 和 og:image 的绝对地址，这些平台拉取卡片预览时需要绝对路径
const ogImageURL = new URL(image, Astro.site);
const pageURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html transition:animate="none" lang="zh-cmn-Hans">
  <head>
    <meta charset="utf-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#1e1e2e" />
    <link rel="icon" href="/images/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    <!-- 不希望被搜索引擎收录，根本不参与索引/追踪链接，配合 public/robots.txt 一起生效 -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Open Graph （分享到 Misskey / 长毛象等联邦宇宙时用于生成预览卡片） -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Curly Sheep" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card（一些联邦实例/客户端也会参考这套标签） -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script is:inline data-astro-rerun>
      const theme = (() => {
        if (
          typeof localStorage !== 'undefined' &&
          localStorage.getItem('theme')
        ) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          return 'light';
        }
        return 'dark';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.remove('light');
      } else {
        document.documentElement.classList.add('light');
      }

      window.localStorage.setItem('theme', theme);

      document.addEventListener('astro:before-swap', (event) => {
        const isLight = document.documentElement.classList.contains('light');
        if (isLight) {
          event.newDocument.documentElement.classList.add('light');
        }
      });

      function initTitleEffect() {
        const originalTitle = document.title;
        const awayTitle = '(つ•̀ω•́)つ 羊等你回来~';
        const backTitle = '欢迎回来！ヽ(・∀・)ﾉ ';

        let hasHidden = false;
        let timer = null;

        if (window.__titleEffectBound) return;
        window.__titleEffectBound = true;

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            hasHidden = true;

            clearTimeout(timer);
            document.title = awayTitle;
          } else {
            if (hasHidden) {
              document.title = backTitle;

              timer = setTimeout(() => {
                document.title = originalTitle;
              }, 600);

              hasHidden = false;
            } else {
              document.title = originalTitle;
            }
          }
        });

        window.addEventListener('pageshow', () => {
          clearTimeout(timer);
          document.title = originalTitle;
        });
      }

      initTitleEffect();
    </script>
    <ClientRouter />
  </head>
  <body class="mt-[78px] mx-auto">
    <Header />
    <main>
      <slot />
      <ScrollToTop />
      <Footer />
    </main>
    <script type="module">
      function attachWalineObserver() {
        const container = document.getElementById('waline');
        if (!container || window.__walineInitialized) return;

        const observer = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (!entry?.isIntersecting) return;

            window.__walineInitialized = true;
            observer.disconnect();

            import('https://unpkg.com/@waline/client@v3/dist/waline.js').then(
              ({ init }) => {
                init({
                  el: '#waline',
                  serverURL:
                    'https://curly-sheeps-comments.netlify.app/.netlify/functions/comment',
                  locale: {
                    placeholder: '跟卷毛羊打个招呼再走吧！',
                    sofa: '还没有评论，来说第一句话吧～',
                    submit: '咩咩',
                    login: '登录',
                    admin: '博主',
                    anonymous: '路过羊',
                  },
                });
              },
            );
          },
          { rootMargin: '300px 0px' },
        );

        observer.observe(container);
      }

      attachWalineObserver();
      document.addEventListener('astro:page-load', attachWalineObserver);
    </script>
    <script>
      function colorMode() {
        if (
          localStorage.theme === 'light' ||
          (!('theme' in localStorage) &&
            window.matchMedia('(prefers-color-scheme: light)').matches)
        ) {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      }

      colorMode();
      document.addEventListener('astro:after-swap', colorMode);
    </script>
  </body>
</html>
