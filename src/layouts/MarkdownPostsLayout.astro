---
import BaseLayout from "./Layout.astro";
const { frontmatter, wordCount, readingTime } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
  <div class="gif">
    <img
      src="/images/mv-dark.png"
      role="presentation"
      width="400"
      height="259"
      decoding="async"
      class="mx-auto theme-img theme-img-dark"
    />
    <img
      src="/images/mv.png"
      role="presentation"
      width="400"
      height="259"
      decoding="async"
      class="mx-auto theme-img theme-img-light"
    />
  </div>
  <h2 style="text-decoration:none" class="postshome">{frontmatter.title}</h2>
  <ul class="badge__list">
    <li>
      <span class="badge badge--item whitespace-nowrap min-w-[87px]"
        >PUBLISHED</span
      >{frontmatter.date}{
        frontmatter.updateDate && `(更新于 ${frontmatter.updateDate})`
      }
    </li>
    <li>
      <span class="badge badge--item">TAGS</span>
      {
        frontmatter.tags.map((tag: string) => (
          <span class="tag-text mr-2">
            <a href={`/tags/${tag}`}>{tag}</a>
          </span>
        ))
      }
    </li>
    <li>
      <span class="badge badge--item">Total Word Count</span>{wordCount} 字
    </li>
    <li>
      <span class="badge badge--item">Reading Time</span>{readingTime} 分钟
    </li>
  </ul>
  <div class="prose">
    <slot />
  </div>
  <div id="waline"></div>
</BaseLayout>

<style>
  .tag {
    margin-right: 15px;
  }

  .theme-img-light {
    display: none;
  }

  :global(.light) .theme-img-dark {
    display: none;
  }
  :global(.light) .theme-img-light {
    display: block;
  }
</style>

<script>
  import mediumZoom from "medium-zoom";

  function initImageZoom() {
    mediumZoom(".prose img", {
      background: "rgba(0, 0, 0, 0.8)",
      margin: 24, // 放大后图片跟屏幕边缘留一点呼吸空间
    });
  }

  initImageZoom();
  document.addEventListener("astro:page-load", initImageZoom);

  // 查找所有代码块
  const blocks = document.querySelectorAll("pre");

  blocks.forEach((block) => {
    const button = document.createElement("button");
    button.innerText = "COPY";
    button.className = "copy-btn";

    // 点击复制逻辑
    button.addEventListener("click", () => {
      const code = block.querySelector("code")?.innerText;
      if (code) {
        navigator.clipboard.writeText(code);
        button.innerText = "Success!";
        setTimeout(() => (button.innerText = "COPY"), 2000);
      }
    });

    block.style.position = "relative";
    block.prepend(button);
  });
</script>

<style>
  /* 简单的样式，你可以根据你的博客主题调整 */
  .copy-btn {
    position: absolute;
    top: 5px;
    right: 5px;
    padding: 4px 8px;
    font-size: 12px;
    cursor: pointer;
    background: #444;
    color: white;
    border: none;
    border-radius: 4px;
  }
</style>
