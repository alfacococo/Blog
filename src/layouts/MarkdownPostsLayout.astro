---
import BaseLayout from './Layout.astro';
import HeroImage from '../components/HeroImage.astro';
import '../styles/waline.css';
const { frontmatter, wordCount, readingTime } = Astro.props;
---

<BaseLayout
  pageTitle={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image?.url}
  type="article"
>
  <div class="gif">
    <HeroImage className="theme-img" />
  </div>
  <h2 style="text-decoration:none" class="postshome">{frontmatter.title}</h2>
  <ul class="badge__list">
    <li>
      <span class="badge badge--item whitespace-nowrap">发布于</span>{
        frontmatter.date
      }{frontmatter.updateDate && `(更新于 ${frontmatter.updateDate})`}
    </li>
    <li>
      <span class="badge badge--item">分类</span>
      {
        frontmatter.tags.map((tag: string) => (
          <span class="tag-text mr-2">
            <a href={`/tags/${tag}`}>{tag}</a>
          </span>
        ))
      }
    </li>
    <li>
      <span class="badge badge--item">总字数</span>{wordCount} 字
    </li>
    <li>
      <span class="badge badge--item">阅读时间</span>{readingTime} 分钟
    </li>
  </ul>
  <div class="prose">
    <slot />
  </div>
  <div id="waline"></div>
</BaseLayout>

<style>
  .tag {
    margin-right: 15px;
  }

  :global(.medium-zoom-overlay),
  :global(.medium-zoom-image--opened) {
    z-index: 9999;
  }
</style>

<script>
  import mediumZoom from 'medium-zoom';

  let zoomInstance: ReturnType<typeof mediumZoom> | null = null;
  let zoomInitQueued = false;

  function initImageZoom() {
    const images = Array.from(document.querySelectorAll('.prose img'));
    if (!images.length) return;

    if (zoomInstance) {
      zoomInstance.detach();
    }

    zoomInstance = mediumZoom(images, {
      background: 'rgba(0, 0, 0, 0.8)',
      margin: 24,
      scrollOffset: 0,
    });
  }

  function queueImageZoomInit() {
    if (zoomInitQueued) return;

    zoomInitQueued = true;
    requestAnimationFrame(() => {
      zoomInitQueued = false;
      initImageZoom();
    });
  }

  document.addEventListener('DOMContentLoaded', queueImageZoomInit);
  document.addEventListener('astro:page-load', queueImageZoomInit);
  document.addEventListener('astro:after-swap', queueImageZoomInit);
  window.addEventListener('load', queueImageZoomInit);

  // 查找所有代码块
  const blocks = document.querySelectorAll('pre');

  blocks.forEach((block) => {
    const button = document.createElement('button');
    button.innerText = 'COPY';
    button.className = 'copy-btn';

    // 点击复制逻辑
    button.addEventListener('click', () => {
      const code = block.querySelector('code')?.innerText;
      if (code) {
        navigator.clipboard.writeText(code);
        button.innerText = 'Success!';
        setTimeout(() => (button.innerText = 'COPY'), 2000);
      }
    });

    block.style.position = 'relative';
    block.prepend(button);
  });
</script>

<style>
  /* 简单的样式，你可以根据你的博客主题调整 */
  .copy-btn {
    position: absolute;
    top: 5px;
    right: 5px;
    padding: 4px 8px;
    font-size: 12px;
    cursor: pointer;
    background: #444;
    color: white;
    border: none;
    border-radius: 4px;
  }
</style>
