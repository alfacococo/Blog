---
import type { GetStaticPathsOptions, Page } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Paginator from '../../components/Paginator.astro';
import HeroImage from '../../components/HeroImage.astro';
import PostCardList from '../../components/PostCardList.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allPosts = (await getCollection('posts')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );

  return paginate(allPosts, { pageSize: 10 });
}

const { page } = Astro.props;
const pageTitle = 'Posts';
---

<Layout pageTitle={pageTitle}>
  <div class="gif">
    <HeroImage className="theme-img" />
  </div>
  <h2 class="text-2xl font-bold underline decoration-[var(--underline)]">
    Blog
  </h2>
  <PostCardList posts={page.data} showNewBadgeOnFirstItem={page.currentPage === 1} />

  <!-- ✅ 分页控件 -->
  <Paginator page={page} basePath="/posts" />
</Layout>
