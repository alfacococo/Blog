---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/Layout.astro';
import { getTagCounts, getSortedTags } from '../../utils/tags';

const allPosts = await getCollection('posts');
const tagCountMap = getTagCounts(allPosts);
const tags = getSortedTags(tagCountMap);

const pageTitle = '标签索引';
---

<BaseLayout pageTitle={pageTitle}>
  <div class="my-8 text-xl border-l-4 pl-4">
    <h3>也可以通过以下标签来查看博文~</h3>
  </div>
  <div class="tags gap-1 flex flex-wrap">
    {
      tags.map((tag) => (
        <p>
          <a
            href={`/tags/${tag}`}
            data-tag-link
            class="tag text-[#ffffff] hover:bg-[#9076a8] active:bg-[#9076a8] focus:bg-[#9076a8] bg-[#584966] transition-colors duration-300 ease-in-out"
          >
            {tag}({tagCountMap[tag]})
          </a>
        </p>
      ))
    }
  </div>
  <style>
    .tag {
      display: inline-block;
      line-height: 1.2;
      font-size: 1rem;
      box-sizing: border-box;
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }

    .tag.is-pressed {
      background-color: #9076a8;
      transform: scale(0.97);
    }
  </style>

  <script>
    import { navigate } from 'astro:transitions/client';

    const attachTagTapFeedback = () => {
      document.querySelectorAll('a[data-tag-link]').forEach((link) => {
        const handlePressStart = () => link.classList.add('is-pressed');
        const handlePressEnd = () => link.classList.remove('is-pressed');

        link.addEventListener('pointerdown', handlePressStart);
        link.addEventListener('pointerup', handlePressEnd);
        link.addEventListener('pointerleave', handlePressEnd);
        link.addEventListener('pointercancel', handlePressEnd);

        link.addEventListener('click', (event) => {
          const href = link.getAttribute('href');
          if (!href) return;

          event.preventDefault();
          link.classList.add('is-pressed');

          window.setTimeout(() => {
            navigate(href);
          }, 120);
        });
      });
    };

    document.addEventListener('astro:page-load', attachTagTapFeedback);
    document.addEventListener('DOMContentLoaded', attachTagTapFeedback);
  </script>
</BaseLayout>
