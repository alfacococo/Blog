---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/Layout.astro';
import { getTagCounts, getSortedTags } from '../../utils/tags';
import PostCardList from '../../components/PostCardList.astro';

const allPosts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const tagCountMap = getTagCounts(allPosts);
const tags = getSortedTags(tagCountMap);

const pageTitle = '标签索引';
---

<BaseLayout pageTitle={pageTitle}>
  <div class="mt-8 md:mt-4 mb-4 text-xl border-l-4 pl-4">
    <h3>也可以通过以下标签来查看博文~</h3>
  </div>
  <div class="tags gap-1 flex flex-wrap">
    {
      tags.map((tag) => (
        <p>
          <button
            type="button"
            data-tag={tag}
            data-tag-link
            class="tag cursor-pointer text-[#ffffff] bg-[#584966] [@media(hover:hover)]:hover:bg-[#9076a8] duration-300 ease-in-out transition"
          >
            {tag}({tagCountMap[tag]})
          </button>
        </p>
      ))
    }
  </div>

  <section class="mt-8" aria-live="polite">
    <h3 id="selected-tag-title" class="my-4 text-xl border-l-4 pl-4">
      请选择一个标签查看对应文章
    </h3>
    <div id="tag-posts-container" data-tag-posts-container>
      <PostCardList posts={allPosts} showTags={true} />
    </div>
  </section>

  <script>
    import { onNavigate } from '../../scripts/onNavigate';
    import { attachPressFeedback } from '../../scripts/attachPressFeedback';
    import {
      applyTagFilter,
      resolveInitialTag,
      setActiveTagLink,
    } from '../../scripts/tagFilter';

    function initTagLinks() {
      attachPressFeedback('[data-tag-link]');

      const tagTitle = document.getElementById('selected-tag-title');
      const allCards = Array.from(
        document.querySelectorAll('a[data-post-card]'),
      );
      const tagLinks = Array.from(
        document.querySelectorAll('[data-tag-link][data-tag]'),
      );

      if (!tagTitle || !allCards.length || !tagLinks.length) return;

      const updateTagQuery = (tag: string) => {
        const url = new URL(window.location.href);
        url.searchParams.set('tag', tag);
        history.replaceState(
          {},
          '',
          `${url.pathname}?${url.searchParams.toString()}`,
        );
      };

      const activateTag = (selectedTag: string, shouldSyncUrl = false) => {
        const activeLink = setActiveTagLink(tagLinks, selectedTag);
        if (!activeLink) return;

        applyTagFilter(allCards, selectedTag);
        tagTitle.textContent = `包含「${selectedTag}」标签的文章`;

        if (shouldSyncUrl) {
          updateTagQuery(selectedTag);
        }
      };

      tagLinks.forEach((link) => {
        link.addEventListener('click', () => {
          const selectedTag = link.getAttribute('data-tag');
          if (!selectedTag) return;

          activateTag(selectedTag, true);
        });
      });

      allCards.forEach((card) => {
        const listItem = card.closest('li');
        if (!listItem) return;
        listItem.style.display = 'none';
      });

      const queryTag = new URLSearchParams(window.location.search).get('tag');
      const { tag: initialTag, isValidQueryTag } = resolveInitialTag(
        tagLinks.map((item) => item.getAttribute('data-tag')),
        queryTag,
      );

      if (initialTag) {
        activateTag(initialTag, !isValidQueryTag);
      }
    }

    onNavigate(initTagLinks);
  </script>
</BaseLayout>
