---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/Layout.astro';

const allPosts = await getCollection('posts');

// ✅ 标签计数对象
const tagCountMap: Record<string, number> = {};

allPosts.forEach((post) => {
  (post.data.tags ?? []).forEach((tag) => {
    if (typeof tag === 'string' && tag.trim() !== '') {
      tagCountMap[tag] = (tagCountMap[tag] || 0) + 1;
    }
  });
});

const tags = Object.keys(tagCountMap).sort(
  (a, b) => tagCountMap[b] - tagCountMap[a],
);

const pageTitle = '标签索引';
---

<BaseLayout pageTitle={pageTitle}>
  <div class="my-8 text-xl border-l-4 pl-4">
    <h3>也可以通过以下标签来查看博文~</h3>
  </div>
  <div class="tags gap-4 flex flex-wrap">
    {
      tags.map((tag) => (
        <p>
          <a
            href={`/tags/${tag}`}
            data-tag-link
            class="tag text-[#ffffff] hover:bg-[#9076a8] active:bg-[#9076a8] focus:bg-[#9076a8] bg-[#584966] transition duration-300 ease-in-out"
          >
            {tag}({tagCountMap[tag]})
          </a>
        </p>
      ))
    }
  </div>
  <style>
    .tag {
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }

    .tag.is-pressed {
      background-color: #9076a8;
      transform: scale(0.97);
    }
  </style>

  <script>
    import { navigate } from 'astro:transitions/client';

    const attachTagTapFeedback = () => {
      document.querySelectorAll('a[data-tag-link]').forEach((link) => {
        const handlePressStart = () => link.classList.add('is-pressed');
        const handlePressEnd = () => link.classList.remove('is-pressed');

        link.addEventListener('pointerdown', handlePressStart);
        link.addEventListener('pointerup', handlePressEnd);
        link.addEventListener('pointerleave', handlePressEnd);
        link.addEventListener('pointercancel', handlePressEnd);

        link.addEventListener('click', (event) => {
          const href = link.getAttribute('href');
          if (!href) return;

          event.preventDefault();
          link.classList.add('is-pressed');

          window.setTimeout(() => {
            navigate(href);
          }, 120);
        });
      });
    };

    document.addEventListener('astro:page-load', attachTagTapFeedback);
    document.addEventListener('DOMContentLoaded', attachTagTapFeedback);
  </script>
</BaseLayout>
